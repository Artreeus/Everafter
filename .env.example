# ──────────────────────────────────────────────────
# Everafter — Environment Variables
# Copy this file to .env.local and fill in the values
# ──────────────────────────────────────────────────

# ── Auth (Auth.js v5) ─────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=
# Your production domain or http://localhost:3000 in dev
AUTH_URL=http://localhost:3000

# ── OAuth Providers ───────────────────────────────
# Google: https://console.cloud.google.com/ → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# GitHub: https://github.com/settings/developers → OAuth Apps
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Database (MongoDB Atlas) ──────────────────────
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=

# ── Cloudinary ────────────────────────────────────
# Dashboard: https://console.cloudinary.com/
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Email (Resend) ────────────────────────────────
# Dashboard: https://resend.com/api-keys
RESEND_API_KEY=
# Must be a verified domain in Resend
RESEND_FROM_EMAIL=hello@yourdomain.com

# ── Background Jobs (Inngest) ─────────────────────
# Dashboard: https://app.inngest.com/ → Settings → Event keys
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ── Stripe (Billing) ─────────────────────────────
# Dashboard: https://dashboard.stripe.com/apikeys (use test keys in dev)
STRIPE_SECRET_KEY=sk_test_...
# For Stripe.js on the client (if needed in future)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Dashboard: https://dashboard.stripe.com/webhooks → Add local listener
# In dev: stripe listen --forward-to localhost:3000/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_...
# Create prices in Stripe Dashboard → Products
STRIPE_PLUS_MONTHLY_PRICE_ID=price_...
STRIPE_PLUS_YEARLY_PRICE_ID=price_...

# ── App ───────────────────────────────────────────
# Your production URL (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000
